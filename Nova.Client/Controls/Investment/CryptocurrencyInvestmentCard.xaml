<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nova.Client.Controls.Investment.CryptocurrencyInvestmentCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nova.Client.Controls.Investment"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Bind Currency}" Grid.Column="0"/>
            <TextBlock Text="{x:Bind Quantity}" Grid.Column="1"/>
        </Grid>
    </Border>
</UserControl>
