<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nova.Client.Controls.ShareInvestmentCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nova.Client.Controls"
    xmlns:converters="using:Nova.Client"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:GainToColorConverter x:Key="GainToColor" />
    </UserControl.Resources>


    <Border CornerRadius="10" Padding="16" Margin="8" BorderThickness="1">
        <StackPanel>
            <TextBlock>
            <Run Text="Ticker: " FontWeight="SemiBold" />
            <Run Text="{x:Bind Ticker}" />
            </TextBlock>

            <TextBlock>
            <Run Text="Quantity: " FontWeight="SemiBold" />
            <Run Text="{x:Bind Quantity}"/>
            </TextBlock>

            <TextBlock>
            <Run Text="Average Price: " FontWeight="SemiBold" />
            <Run Text="{x:Bind AveragePrice}"/>
            </TextBlock>

            <TextBlock>
            <Run Text="Current Price: " FontWeight="SemiBold" />
            <Run Text="{x:Bind CurrentPrice}"/>
            </TextBlock>

            <TextBlock>
            <Run Text="Gain: " FontWeight="SemiBold" />
            <Run Text="{x:Bind GainFormat}" 
                 Foreground="{x:Bind Gain, Converter={StaticResource GainToColor}}" />
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>
